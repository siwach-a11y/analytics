{
  "name": "agenthub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true; lsof -ti :3001 | xargs kill -9 2>/dev/null || true; rm -rf .next && next dev -p 3000",
    "build": "next build",
    "build:html": "node scripts/build-html.mjs",
    "build:pages": "GITHUB_PAGES=1 node scripts/build-html.mjs",
    "deploy:pages": "node scripts/deploy-gh-pages.mjs",
    "start": "next start",
    "lint": "next lint",
    "dev:sniper-backend": "npm run dev:backend --prefix ../ticket-sniper-bot",
    "telecom:dev": "npm run dev --prefix telecom-dapp-dashboard",
    "telecom:build": "npm run build --prefix telecom-dapp-dashboard",
    "telecom:start": "npm run start --prefix telecom-dapp-dashboard",
    "analytics:dev": "npm run dev --prefix analytics-dashboard",
    "analytics:build": "npm run build --prefix analytics-dashboard",
    "analytics:exports": "node scripts/build-export-zips.mjs",
    "analytics:start": "npm run start --prefix analytics-dashboard",
    "exports:copy:customer": "node scripts/copy-export.mjs customer-analytics your-project/src",
    "exports:copy:marketing": "node scripts/copy-export.mjs marketing-intelligence your-project/src",
    "exports:copy:analytics": "node scripts/copy-export.mjs analytics-feature your-project/src",
    "exports:copy:all": "node scripts/copy-export.mjs customer-analytics your-project/src && node scripts/copy-export.mjs marketing-intelligence your-project/src && node scripts/copy-export.mjs analytics-feature your-project/src",
    "analytics:demo": "node scripts/build-analytics-demo.mjs",
    "analytics:demo:refresh": "npm run analytics:demo && lsof -ti :3457 | xargs kill -9 2>/dev/null || true; npm run analytics:demo:serve",
    "analytics:demo:pages": "GITHUB_PAGES=1 node scripts/build-analytics-demo.mjs",
    "analytics:demo:serve": "npx --yes serve analytics-dashboard-demo -p 3457"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
