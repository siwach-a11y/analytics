# ── BNII Analytics API ────────────────────────────────────────────────────────
# The dashboard reads live per-telco metrics from the BNII Analytics API.
# When a partner UUID is set, that workspace shows REAL data from the API
# (including real zeros). When it is unset, the field renders "—" / falls back to
# the projected config baseline — it is never styled as real.
#
# Get the nine partner UUIDs from Rahul (BNII) or atlas-prod
# (app/services/bnii_ingest.py → WORKSPACE_TO_PARTNER). Do NOT commit real UUIDs.

# Base URL + optional bearer token (the public API is currently unauthenticated).
BNII_ANALYTICS_BASE_URL=https://bnii-analytics-api-epgxydm2fa-as.a.run.app
# BNII_ANALYTICS_TOKEN=

# One UUID per telco partner. NEXT_PUBLIC_ so the static export / client can read
# them; for a server deployment a same-origin proxy (/api/bnii/metrics/query) is
# used so the browser never calls the public API directly.
NEXT_PUBLIC_BNII_PARTNER_ID_U9=
NEXT_PUBLIC_BNII_PARTNER_ID_DIALOG=
NEXT_PUBLIC_BNII_PARTNER_ID_TELKOMSEL=
NEXT_PUBLIC_BNII_PARTNER_ID_BANGLALINK=
NEXT_PUBLIC_BNII_PARTNER_ID_ROBI_MYAIRTEL=
NEXT_PUBLIC_BNII_PARTNER_ID_GOPAY=
NEXT_PUBLIC_BNII_PARTNER_ID_BIMA=
NEXT_PUBLIC_BNII_PARTNER_ID_MYIM3=
NEXT_PUBLIC_BNII_PARTNER_ID_OKARA=

# Optional shared fallback used when a per-telco UUID above is blank.
# NEXT_PUBLIC_BNII_PARTNER_ID=
