# Server-side key for local dev (used by the /api/chat route). Never public.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Static demo only: URL of the serverless chat proxy (see proxy/README.md).
# The key lives in the proxy's secrets, NOT here. Leave unset for local dev.
# NEXT_PUBLIC_CHAT_PROXY_URL=https://voucher-chat-proxy.<you>.workers.dev

# Operator pipeline passphrase (gates /operator + discovery/queue APIs). Unset = open in dev.
OPERATOR_PASSPHRASE=
